# Framefore — environment variables
# Copy this file to `.env.local` and fill in the values from your Supabase project.
# `.env.local` is gitignored and must never be committed.

# Supabase project URL and PUBLIC anon key.
# Dashboard → Project Settings → API.
# The anon key is safe to ship in the frontend; it is protected by Row Level Security.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_APP_URL=http://localhost:5173
VITE_APP_ENV=local

# NEVER put the Supabase service_role key here or anywhere in the frontend / VITE_* vars.
# It bypasses Row Level Security and must only live in trusted server environments.

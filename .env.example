# Framefore — environment variables
# Copy this file to `.env.local` and fill in the values from your Supabase project.
# `.env.local` is gitignored and must never be committed.

# =========================================================
# Supabase
# =========================================================
# Dashboard → Project Settings → API.
# VITE_SUPABASE_URL is safe to expose.
# VITE_SUPABASE_ANON_KEY / publishable key is safe when RLS is enabled.
# NEVER put the Supabase service_role key here or anywhere in the frontend / VITE_* vars.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# =========================================================
# App URLs
# =========================================================
VITE_APP_URL=http://localhost:5173
VITE_APP_ENV=local

# =========================================================
# OAuth Provider Setup Notes
# =========================================================
# Google and GitHub OAuth are configured in:
# Supabase Dashboard → Authentication → Sign In / Providers
#
# These provider credentials are NOT used directly by the Vite frontend.
# GOOGLE_OAUTH_CLIENT_SECRET and GITHUB_OAUTH_CLIENT_SECRET must never be prefixed with VITE_.
# Provider secrets are configured inside Supabase Dashboard, not read by the frontend app.
#
# Local app redirect URL:
# http://localhost:5173/auth/callback
#
# Production app redirect URL after deployment:
# https://YOUR_DOMAIN.com/auth/callback

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
